{
  "name": "sparkle-shine-backend",
  "version": "1.0.0",
  "description": "Backend API for Sparkle & Shine Professional Cleaning - MongoDB",
  "main": "dist/app.ts",
  "scripts": {
    "dev": "nodemon src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "docker:up": "docker-compose up -d",
